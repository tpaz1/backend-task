{
  "info": {
    "name": "Aim Prompt Guardrail",
    "description": "Topic-detection service for GenAI pipelines. Classifies prompts against sensitive topic categories (health, finance, legal, hr) before they reach a downstream model.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health check",
      "description": "Liveness probe. Returns {\"status\": \"ok\"} when the service is running. Use this to confirm the container is up before running other requests.",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health",
        "header": []
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"status 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"returns ok\", () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.status).to.eql(\"ok\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Detect — spec example",
      "description": "The canonical example from the spec: a health-related prompt with health and hr enabled. Expects exactly [\"health\"] — the prompt clearly relates to health but not to hr.",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/detect",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"prompt\": \"How would you suggest to treat depression?\",\n  \"settings\": {\n    \"health\": true,\n    \"finance\": false,\n    \"hr\": true,\n    \"legal\": false\n  }\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"status 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"detected_topics is an array\", () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.detected_topics).to.be.an(\"array\");",
              "});",
              "pm.test(\"health topic detected\", () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.detected_topics).to.include(\"health\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Protect — multi-topic prompt",
      "description": "Fail-fast variant: returns as soon as one matching topic is found. This prompt touches health, hr, and legal — /protect must return exactly one of the enabled matches, not all of them.",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/protect",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"prompt\": \"A nurse negotiating her salary under a new employment contract\",\n  \"settings\": {\n    \"health\": true,\n    \"finance\": false,\n    \"hr\": true,\n    \"legal\": true\n  }\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"status 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"detected_topics is an array\", () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.detected_topics).to.be.an(\"array\");",
              "});",
              "pm.test(\"at most one topic returned\", () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.detected_topics.length).to.be.at.most(1);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Audit log",
      "description": "Returns the full in-memory audit trail of all /detect and /protect calls since the service started. Each entry includes timestamp, endpoint, prompt, and detected_topics.",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/logs",
        "header": []
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"status 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"response is an array\", () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.be.an(\"array\");",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
